# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Modello Claude:
#   claude-haiku-4-5-20251001  → Bootstrap (20x meno costoso, ~$3/mese)
#   claude-sonnet-4-6          → Produzione (qualità superiore, ~$20/mese)
CLAUDE_MODEL=claude-haiku-4-5-20251001


# ─── TTS Provider ─────────────────────────────────────────────────────────────
#   azure       → Free tier 500.000 chars/mese, poi $1/milione (CONSIGLIATO bootstrap)
#   elevenlabs  → $5–$99/mese a seconda del piano
TTS_PROVIDER=azure


# ─── Azure TTS ────────────────────────────────────────────────────────────────
# Crea risorsa "Speech" su portal.azure.com → piano Free F0
# Voci italiane: it-IT-DiegoNeural, it-IT-ElsaNeural,
#                it-IT-IsabellaNeural, it-IT-GiuseppeNeural
AZURE_TTS_KEY=your-azure-key
AZURE_TTS_REGION=westeurope
AZURE_TTS_VOICE=it-IT-DiegoNeural


# ─── ElevenLabs (solo se TTS_PROVIDER=elevenlabs) ─────────────────────────────
ELEVENLABS_API_KEY=sk_...


# ─── Cron & News ──────────────────────────────────────────────────────────────
# Secret casuale per proteggere /api/cron (es: openssl rand -hex 32)
CRON_SECRET=cambia-con-stringa-random

NEWS_CATEGORIA=Italia
NEWS_NUM=5
